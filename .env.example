# Copy to .env and fill in. Never commit the real .env.
# ─────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────
# ARXIV_DOWNLOAD_DIR=~/arxiv-papers
# ARXIV_DB_PATH=~/arxiv-papers/arxiv_index.db
# ARXIV_CHUNK_SIZE=1500
# ARXIV_CHUNK_OVERLAP=200

# ── DOI / Open Access ────────────────────────────────
# Real email for Unpaywall OA lookups (improves PDF discovery).
# UNPAYWALL_EMAIL=you@example.com

# ── OpenAlex ──────────────────────────────────────────
# Email for the polite pool (higher rate limits, not required).
# OPENALEX_EMAIL=you@example.com

# ── CORE ──────────────────────────────────────────────
# Free API key from https://core.ac.uk/services/api
CORE_API_KEY=

# ── Cloud Documentation ──────────────────────────────
# Google API key — required for search_gcp_docs AND search_iam_docs.
# Enable BOTH "Developer Knowledge API" and "Custom Search API" in the
# same Google Cloud project, then create an API key restricted to those
# two APIs. Reused by both tools.
GOOGLE_DEVKNOWLEDGE_API_KEY=

# ── IAM Documentation ────────────────────────────────
# Programmable Search Engine ID (cx) — required for search_iam_docs.
# Create a PSE at programmablesearchengine.google.com scoped to the IAM
# doc sites listed in IAM_DOCS_DOMAINS in server.py, then paste the
# Search Engine ID here. Not secret.
GOOGLE_PSE_CX=

# Force a specific IAM search provider instead of auto-detection.
# Options: vertex, brave, serpapi, google, auto (default).
# IAM_DOCS_SEARCH_PROVIDER=auto

# Vertex AI Search (optional, highest quality for IAM docs).
# VERTEX_AI_PROJECT=your-gcp-project-id
# VERTEX_AI_LOCATION=global
# VERTEX_AI_IAM_ENGINE_ID=your-engine-id

# Brave Search API (optional IAM docs fallback).
# BRAVE_SEARCH_API_KEY=

# SerpAPI (optional IAM docs fallback).
# SERPAPI_API_KEY=

# ── GitHub ────────────────────────────────────────────
# GitHub PAT — optional for search_github_repos (raises rate limit to
# 5000/hr), required for search_github_code. Use a fine-grained token
# with only public-repo read access.
GITHUB_TOKEN=

# ── Analytics ─────────────────────────────────────────
# Root directory for Parquet/CSV/JSON dataset files.
# DUCKDB_DATASETS_DIR=~/research-datasets

# ── Embeddings ────────────────────────────────────────
# Local ONNX embedding model for semantic search.
# EMBED_MODEL_NAME=BAAI/bge-small-en-v1.5
# EMBED_DIM=384
# EMBED_DB_PATH=~/arxiv-papers/embeddings.duckdb
